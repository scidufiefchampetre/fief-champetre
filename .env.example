# ─────────────────────────────────────────────────────────────────────────────
# Fief Champêtre — Variables d'environnement
# Copier ce fichier en .env et renseigner toutes les valeurs avant de démarrer.
# Ces variables restent EXCLUSIVEMENT côté serveur (ne jamais préfixer avec VITE_,
# sauf VITE_USE_MOCK_DATA qui est inoffensif car il ne contient aucun secret).
# ─────────────────────────────────────────────────────────────────────────────

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Compte de service : scidufiefchampetre@gmail.com (ou tout compte ayant accès
# aux ressources Google ci-dessous).
# Créer les identifiants dans Google Cloud Console → APIs & Services → Credentials
# → "OAuth 2.0 Client ID" (type : "Web application" ou "Desktop app").
# Générer le refresh token via https://developers.google.com/oauthplayground/
# (scopes requis : Calendar, Sheets, Drive — voir docs/INTEGRATIONS.md).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# ── Google Calendar ───────────────────────────────────────────────────────────
# ID de l'agenda partagé du Fief (ex : lesenfantsdufiefchampetre@gmail.com).
# Visible dans les paramètres de l'agenda Google → "Intégrer l'agenda".
GOOGLE_CALENDAR_ID=

# ── Google Sheets : classeur principal ────────────────────────────────────────
# Contient les onglets : SCI, Asso, Membres, Réservations.
# L'app peut le créer automatiquement si absent ; l'ID se trouve dans l'URL
# du classeur : docs.google.com/spreadsheets/d/<ID>/edit
GOOGLE_SHEETS_SPREADSHEET_ID=

# ── Google Sheets : classeur Chantiers ────────────────────────────────────────
# Contient les onglets : Chantier Overview, Tâches, Inscriptions, Intendance,
# Suivi jours chantiers.
# Créé automatiquement par l'app si absent.
GOOGLE_CHANTIERS_SPREADSHEET_ID=

# ── Google Sheets : classeur Feedback ─────────────────────────────────────────
# Contient les onglets : Bugs, Idées.
# Créé automatiquement par l'app au premier retour utilisateur.
# Optionnel au démarrage — l'ID est loggué dans la console Worker à la création.
GOOGLE_FEEDBACK_SPREADSHEET_ID=

# ── Google Drive : dossiers de stockage des justificatifs ─────────────────────
# Dossier Drive où sont déposées les photos de factures SCI.
# ID dans l'URL : drive.google.com/drive/folders/<ID>
# Créé automatiquement si absent ; l'ID est loggué dans la console Worker.
GOOGLE_DRIVE_FOLDER_SCI_ID=

# Même chose pour les factures Asso.
GOOGLE_DRIVE_FOLDER_ASSO_ID=

# ── Anthropic (analyse automatique des factures) ──────────────────────────────
# Clé API pour l'extraction des données de facture par IA.
# console.anthropic.com/settings/keys
# Si absente, l'interface bascule en saisie manuelle (pas de blocage).
ANTHROPIC_API_KEY=
# Modèle optionnel (défaut : claude-haiku-4-5-20251001)
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Mots de passe admin ───────────────────────────────────────────────────────
# Protègent l'espace Trésorier (SCI et Asso). Choisir des valeurs fortes.
ADMIN_SCI_PASSWORD=
ADMIN_ASSO_PASSWORD=

# ── Mode mock (développement) ─────────────────────────────────────────────────
# Mettre à "true" pour désactiver tous les appels Google et Anthropic.
# Permet de développer sans accès réseau ni credentials.
# Mettre à "false" (ou supprimer) en production.
VITE_USE_MOCK_DATA=false

# ── Cloudflare Workers (déploiement uniquement) ───────────────────────────────
# Token API pour déployer via wrangler. Créer sur :
# https://dash.cloudflare.com/profile/api-tokens → "Edit Cloudflare Workers"
# Uniquement nécessaire pour la commande de déploiement ; pas besoin en dev local.
CLOUDFLARE_API_TOKEN=
